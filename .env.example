# ─────────────────────────────────────────────────────────────
# AI Humanizer — Environment Variables
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
#
# NEVER commit .env.local — it is gitignored by default.
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────

# Groq API key (get yours free at https://console.groq.com)
# Used for all AI features: humanizer, paraphraser, detector, plagiarism checker
GROQ_API_KEY=your_groq_api_key_here

# ── Optional ──────────────────────────────────────────────────

# Google Analytics 4 Measurement ID
# Format: G-XXXXXXXXXX  (found in GA4 → Admin → Data Streams)
# Leave blank to disable analytics tracking
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
